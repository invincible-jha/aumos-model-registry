# ============================================================================
# .env.example — AumOS Model Registry
# Copy to .env and fill in values for local development.
# NEVER commit .env to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Core AumOS settings (from aumos-common)
# ---------------------------------------------------------------------------
AUMOS_SERVICE_NAME=aumos-model-registry
AUMOS_ENVIRONMENT=development

# PostgreSQL (pgvector/pgvector:pg16)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos

# Kafka
AUMOS_KAFKA__BROKERS=localhost:9092
AUMOS_KAFKA__SECURITY_PROTOCOL=PLAINTEXT

# JWT Auth
AUMOS_AUTH__SECRET_KEY=dev-secret-change-in-production
AUMOS_AUTH__ALGORITHM=HS256
AUMOS_AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=60

# Observability
AUMOS_OTEL__ENDPOINT=http://localhost:4317
AUMOS_OTEL__ENABLED=false
AUMOS_LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Registry-specific settings (AUMOS_REGISTRY_ prefix)
# ---------------------------------------------------------------------------

# MLflow integration
AUMOS_REGISTRY_MLFLOW_TRACKING_URI=postgresql+psycopg2://aumos:aumos_dev@localhost:5432/aumos
AUMOS_REGISTRY_MLFLOW_ARTIFACT_ROOT=s3://aumos-model-artifacts
AUMOS_REGISTRY_MLFLOW_SERVER_PORT=5000

# MinIO / S3 artifact storage
AUMOS_REGISTRY_ARTIFACT_STORE=http://localhost:9000
AUMOS_REGISTRY_ARTIFACT_BUCKET_PREFIX=reg-models

# MinIO credentials (for local dev via docker-compose.dev.yml)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Cost tracking defaults (USD)
AUMOS_REGISTRY_DEFAULT_GPU_HOURLY_COST_USD=3.50
AUMOS_REGISTRY_DEFAULT_CPU_HOURLY_COST_USD=0.10
AUMOS_REGISTRY_DEFAULT_STORAGE_GB_MONTHLY_COST_USD=0.023

# Semantic search
AUMOS_REGISTRY_EMBEDDING_MODEL=text-embedding-3-small
AUMOS_REGISTRY_EMBEDDING_DIMENSIONS=1536

# Production stage gate (set to false to disable approval requirement in dev)
AUMOS_REGISTRY_REQUIRE_APPROVAL_FOR_PRODUCTION=false
